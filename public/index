            <i class="fas fa-sliders-h w-5 h-5 mr-3"></i><span>Setup Akun</span>
        </a>
        <a href="#" id="nav-stats" class="nav-item flex items-center px-4 py-3 text-sm font-medium text-gray-600 hover:text-indigo-700">
            <i class="fas fa-chart-bar w-5 h-5 mr-3"></i><span>Statistik</span>
