<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Warmer • Spark</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Inter', system-ui, sans-serif; background: #f8fafc; }
        .sidebar { transition: all 0.2s; }
        .nav-item { transition: all 0.15s; border-radius: 10px; }
        .nav-item:hover { background-color: #eef2ff; }
        .nav-item.active { background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%); color: white; }
        .nav-item.active i { color: white; }
        .btn-gradient { background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%); }
        .btn-gradient:hover { opacity: 0.9; }
        .custom-scroll::-webkit-scrollbar { width: 5px; }
        .custom-scroll::-webkit-scrollbar-track { background: #f1f5f9; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 8px; }
        .log-container::-webkit-scrollbar { width: 5px; }
        .log-container::-webkit-scrollbar-track { background: #1e293b; }
        .log-container::-webkit-scrollbar-thumb { background: #475569; border-radius: 8px; }
        .pairing-grid { max-height: 400px; overflow-y: auto; }
        .pairing-dark-bg { background: #1e1e2f; border-color: #2d2d44; }
    </style>
</head>
<body class="h-screen flex overflow-hidden">

<!-- SIDEBAR -->
